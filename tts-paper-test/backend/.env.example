# TSS AI测试平台 - 环境变量配置

# 数据库 (开发用SQLite, 生产用PostgreSQL)
DATABASE_URL=sqlite+aiosqlite:///./tss_dev.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/tss_prod

# JWT密钥 (生产环境请修改)
SECRET_KEY=your-secret-key-change-in-production

# AI模型配置
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# Midscene.js 视觉模型
MIDSCENE_MODEL_NAME=qwen3.7-plus
MIDSCENE_MODEL_API_KEY=your-qwen-api-key
MIDSCENE_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MIDSCENE_MODEL_FAMILY=qwen3

# 调试模式
DEBUG=true
