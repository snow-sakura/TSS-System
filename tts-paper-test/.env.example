# TSS Paper Test - 环境变量配置
# 复制此文件为 .env 并填入实际值

# ===== LLM API Keys =====
# OpenAI (推荐)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===== 被测系统配置 =====
TSS_BASE_URL=http://127.0.0.1:5000
TSS_API_BASE=http://127.0.0.1:5000/api

# ===== 测试账号 =====
TSS_ADMIN_USERNAME=admin
TSS_ADMIN_PASSWORD=admin123
TSS_TEST_USERNAME=testuser
TSS_TEST_PASSWORD=test123

# ===== 向量数据库 =====
CHROMA_PERSIST_DIRECTORY=./chroma_db
CHROMA_COLLECTION_NAME=tss_test_knowledge

# ===== 嵌入模型 =====
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ===== 测试配置 =====
TEST_ENVIRONMENT=development
TEST_TIMEOUT=30
TEST_RETRY_COUNT=3

# ===== 报告配置 =====
REPORT_DIRECTORY=./reports
REPORT_FORMAT=html
